FROM node:20-slim

WORKDIR /app

# We will mount the volume, so we just need to ensure dependencies are installed if package.json exists
# But initially, we might need to create the app. 
# For the first run, we'll assume the user might not have package.json yet if we haven't scaffolded it.
# However, the plan says we will scaffold it. 
# Let's set it up to install and run dev.

CMD ["sh", "-c", "npm install && npm run dev -- --host"]
